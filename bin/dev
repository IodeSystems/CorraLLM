#!/usr/bin/env bash
# Dev hot-reload: air (Go server on :6502) + Vite (UI on :6503, proxies /api).
# Frees both ports first, runs air in the background and Vite in the foreground;
# Ctrl-C tears both down.
set -euo pipefail

root="$(cd "$(dirname "$0")/.." && pwd)"
cd "$root"

API_PORT="${API_PORT:-6502}"
UI_PORT="${UI_PORT:-6503}"

free_port() { lsof -ti tcp:"$1" 2>/dev/null | xargs -r kill 2>/dev/null || true; }
free_port "$API_PORT"
free_port "$UI_PORT"

export ADDR="${ADDR:-:$API_PORT}"

cleanup() { [[ -n "${AIR_PID:-}" ]] && kill "$AIR_PID" 2>/dev/null || true; }
trap cleanup EXIT INT TERM

echo "==> air: Go server on $ADDR"
air -c .air.toml &
AIR_PID=$!

echo "==> vite: UI on :$UI_PORT (proxying /api → :$API_PORT)"
cd ui
[[ -d node_modules ]] || pnpm install
[[ -d src/gql ]] || pnpm gen
exec pnpm dev
